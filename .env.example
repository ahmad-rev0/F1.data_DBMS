# Copy to .env and adjust. Do not commit .env.

MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=formula1
MYSQL_USER=f1_app
MYSQL_PASSWORD=changeme_app
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# Aiven / managed MySQL (TLS). Local MySQL: leave unset or MYSQL_USE_SSL=false
# MYSQL_USE_SSL=true
# MYSQL_SSL_CA=D:/path/to/ca.pem
# MYSQL_SSL_CA_PEM=-----BEGIN CERTIFICATE----- ... (multiline; Render secret)

DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Production (Render + Vercel): set DJANGO_PRODUCTION=true or deploy on Render (sets RENDER=true).
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-service.onrender.com
# DJANGO_CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-app-git-main.vercel.app
